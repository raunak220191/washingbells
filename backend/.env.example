# --- WashingBells Backend Environment ---
# Copy this file to .env and fill in your values

# MongoDB
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=washingbells

# JWT
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# SMS & OTP — Twilio Verify (SERVER-SIDE ONLY — never put these in the mobile app).
# Leave empty to use the dev bypass (OTP is always 123456).
TWILIO_ACCOUNT_SID=your_twilio_account_sid                # ACxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_VERIFY_SERVICE_SID=your_twilio_verify_service_sid  # VAxxxxxxxx
# Optional — invitation SMS (rider/store) via Twilio Messaging (set one):
TWILIO_MESSAGING_SERVICE_SID=                             # MGxxxxxxxx (preferred)
TWILIO_FROM_NUMBER=                                       # +1xxxxxxxxxx

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Google Maps
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# App
DEBUG=true
