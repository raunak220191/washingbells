{
  "expo": {
    "name": "WashingBells Store",
    "slug": "washingbells-store",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#F5F5F2",
      "resizeMode": "contain",
      "image": "./assets/splash-icon.png"
    },
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/icon-ios.png",
      "bundleIdentifier": "com.washingbells.store",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": [
          "remote-notification"
        ],
        "NSLocationWhenInUseUsageDescription": "WashingBells Store needs your location to pin your store on the map."
      }
    },
    "android": {
      "package": "com.washingbells.store",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#006241"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.VIBRATE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-image-picker",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "WashingBells Store needs your location to pin your store on the map."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#006241",
          "defaultChannel": "default"
        }
      ],
      "expo-font"
    ],
    "scheme": "store",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "37c10ca7-fb45-491b-a431-e0f0b287b39f"
      }
    },
    "owner": "rp2201"
  }
}
